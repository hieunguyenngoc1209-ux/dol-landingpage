    <!-- LOGIC JAVASCRIPT ĐIỀU KHIỂN CHAT VÀ TRẮC NGHIỆM ĐỘC LẬP -->
    <script>
        // Điều khiển Mobile Menu
        const mobileBtn = document.getElementById('mobileMenuBtn');
        const mobileMenu = document.getElementById('mobileMenu');
        mobileBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));

        // Điều khiển Chat Panel
        const chatPanel = document.getElementById('chatPanel');
        const chatMessages = document.getElementById('chatMessages');
        const chatInput = document.getElementById('chatInput');

        function toggleChatPanel() {
            if(chatPanel.classList.contains('hidden')) {
                chatPanel.classList.remove('hidden');
                chatPanel.classList.add('flex');
                chatInput.focus();
            } else {
                chatPanel.classList.remove('flex');
                chatPanel.classList.add('hidden');
            }
        }
        document.getElementById('chatToggle').addEventListener('click', toggleChatPanel);
        document.getElementById('chatClose').addEventListener('click', () => {
            chatPanel.classList.remove('flex');
            chatPanel.classList.add('hidden');
        });

        function addMsg(text, isUser = false) {
            const div = document.createElement('div');
            div.className = isUser 
                ? 'ml-auto max-w-[85%] rounded-2xl rounded-tr-md bg-dol-red p-3.5 text-white leading-relaxed' 
                : 'max-w-[85%] rounded-2xl rounded-tl-md bg-white p-3.5 shadow-sm border border-gray-100 leading-relaxed';
            div.textContent = text;
            chatMessages.appendChild(div);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        document.getElementById('chatForm').addEventListener('submit', e => {
            e.preventDefault();
            const msg = chatInput.value.trim();
            if(!msg) return;
            addMsg(msg, true);
            chatInput.value = '';

            // Tạo hiệu ứng ba dấu chấm đang gõ
            const typing = document.createElement('div');
            typing.className = 'max-w-[85%] rounded-2xl rounded-tl-md bg-white p-4 shadow-sm border border-gray-100';
            typing.innerHTML = '<span class="typing-dot"></span> <span class="typing-dot"></span> <span class="typing-dot"></span>';
            chatMessages.appendChild(typing);
            chatMessages.scrollTop = chatMessages.scrollHeight;

            setTimeout(() => {
                typing.remove();
                addMsg("Cảm ơn thông tin từ bạn! Cố vấn chuyên môn của DOL sẽ kết nối trực tiếp để xây dựng lộ trình học cá nhân hóa cho mình nha. Bạn có thể đăng ký nhanh qua biểu mẫu bên trái trang web để được ưu tiên xử lý hồ sơ sớm nhất hằng ngày nhé! ✨");
            }, 1000);
        });

        // Xử lý sự kiện bấm chọn đáp án trắc nghiệm nhanh
        document.querySelectorAll('.quiz-option').forEach(btn => {
            btn.addEventListener('click', () => {
                const parent = btn.closest('.quiz-q');
                parent.querySelectorAll('.quiz-option').forEach(opt => opt.classList.remove('active'));
                btn.classList.add('active');
            });
        });

        document.getElementById('submitQuiz').addEventListener('click', () => {
            const q = document.querySelector('.quiz-q');
            const picked = q.querySelector('.quiz-option.active');
            const box = document.getElementById('quizResult');
            box.classList.remove('hidden');

            if (picked && picked.dataset.value === q.dataset.answer) {
                box.innerHTML = '<div class="font-extrabold text-green-700 text-base">🎉 CHÍNH XÁC!</div><p class="mt-2 text-sm leading-relaxed text-gray-700">Áp dụng cấu trúc cốt lõi trục chính (S-V-O) của phương pháp LinearThinking giúp bạn hiểu trọn vẹn ngữ nghĩa câu dài mà không lo cạn kiệt thời gian làm bài trong phòng thi!</p>';
            } else {
                box.innerHTML = '<div class="font-extrabold text-dol-red text-base">❌ CHƯA CHÍNH XÁC!</div><p class="mt-2 text-sm leading-relaxed text-gray-700">Thói quen dịch word-by-word từng từ sẽ làm bạn bị ngợp và mất rất nhiều thời gian. Hãy thử chọn lại phương án tìm cấu trúc cốt lõi (S-V-O) xem sao nhé!</p>';
            }
        });
    </script>
</body>
