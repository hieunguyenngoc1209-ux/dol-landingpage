    <script>
        // Logic mini-app trắc nghiệm nhanh
        function runQuiz(element, isCorrect, msg) {
            const options = element.parentElement.querySelectorAll('.option-item');
            options.forEach(opt => opt.style.pointerEvents = 'none');

            if(isCorrect) {
                element.classList.add('correct');
                setTimeout(() => {
                    document.getElementById('testQuestionBox').style.display = 'none';
                    document.getElementById('testResultBox').style.display = 'block';
                    document.getElementById('quizExplain').innerText = msg;
                    document.querySelector('.test-progress-bar').style.width = '100%';
                }, 800);
            } else {
                element.style.borderColor = 'var(--dol-red)';
                element.style.backgroundColor = '#fce8e6';
                alert(msg);
                options.forEach(opt => opt.style.pointerEvents = 'auto');
            }
        }

        // Logic điều khiển ẩn hiện và tự động trả lời của Chatbox AI
        const chatToggleBtn = document.getElementById('chatToggleBtn');
        const chatWindow = document.getElementById('chatWindow');
        const chatCloseBtn = document.getElementById('closeChatBtn');
        const chatSendBtn = document.getElementById('chatSendBtn');
        const chatInputField = document.getElementById('chatInputField');
        const chatMessagesBox = document.getElementById('chatMessagesBox');

        chatToggleBtn.addEventListener('click', () => {
            chatWindow.style.display = chatWindow.style.display === 'flex' ? 'none' : 'flex';
            if(chatWindow.style.display === 'flex') chatInputField.focus();
        });
        chatCloseBtn.addEventListener('click', () => { chatWindow.style.display = 'none'; });

        function handleSendMessage() {
            const txt = chatInputField.value.trim();
            if(!txt) return;

            const uB = document.createElement('div');
            uB.className = 'msg-bubble user';
            uB.innerText = txt;
            chatMessagesBox.appendChild(uB);
            chatInputField.value = "";
            chatMessagesBox.scrollTop = chatMessagesBox.scrollHeight;

            setTimeout(() => {
                const bB = document.createElement('div');
                bB.className = 'msg-bubble bot';
                bB.innerText = "Cảm ơn thông tin từ bạn! Câu hỏi đã được chuyển tới thầy cô ban cố vấn học thuật học viện DOL English. Bạn vui lòng để lại số điện thoại và mục tiêu lớp học tại biểu mẫu (Form) đăng ký trên trang để bên mình gọi điện hỗ trợ xếp lịch test chi tiết nhé! ✨";
                chatMessagesBox.appendChild(bB);
                chatMessagesBox.scrollTop = chatMessagesBox.scrollHeight;
            }, 1000);
        }

        chatSendBtn.addEventListener('click', handleSendMessage);
        chatInputField.addEventListener('keypress', (e) => { if(e.key === 'Enter') handleSendMessage(); });
    </script>
